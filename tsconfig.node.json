{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/main",
    "rootDir": "./src"
  },
  "include": ["src/main/**/*.ts", "src/core/**/*.ts", "src/db/**/*.ts", "src/preload.d.ts"]
}
